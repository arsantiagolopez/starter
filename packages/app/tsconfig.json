{
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "esnext",
    "target": "es2020",
    "lib": ["es2020", "dom"],
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@starter/ui": ["../ui/src/index.universal.ts"],
      "@starter/ui/*": ["../ui/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}